{
  "functions": {
    "source": "functions",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.local"
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "figurestore-68028",
          "appId": "1:403509884500:android:6e9edc5abf270b6bf9dfc1",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "figurestore-68028",
          "configurations": {
            "android": "1:403509884500:android:6e9edc5abf270b6bf9dfc1",
            "web": "1:403509884500:web:49ff4e8746ab9804f9dfc1"
          }
        }
      }
    }
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
